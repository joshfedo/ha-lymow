# Secrets and captured traffic — never commit these
*.pcap
*.pcapng
*.har
*.txt
*.log
*.cfa
secrets.yaml
.env
capture-*.txt
tools/_*

# APK analysis binaries (large, not for VCS)
tools/apk/

# Generated script outputs
scripts/map.png
scripts/map_response.bin

# Capture output files (may contain device IDs / PII)
tools/*.jsonl
tools/*.bin

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Editor
.vscode/
*.swp

# Local AI session task tracking
.todo
plan.md
.coverage

# dotclaude runtime lock (never commit)
.claude/scheduled_tasks.lock

# dotclaude:begin
.claude/plans/
CLAUDE.local.md
.claude/settings.local.json
# dotclaude:end
